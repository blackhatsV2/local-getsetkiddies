<!-- Global Toast Notification -->
<div id="globalToast" class="toast-container" style="display: none;">
  <div class="toast-content">
    <span id="toastMessage"></span>
    <button id="closeToast" class="toast-close">&times;</button>
  </div>
</div>

<!-- Global Confirmation Modal -->
<div id="globalModal" class="modal-overlay" style="display: none;">
  <div class="modal-box">
    <div class="modal-body">
      <p id="modalMessage"></p>
    </div>
    <div class="modal-footer">
      <button id="modalCancel" class="modal-btn cancel">Cancel</button>
      <button id="modalConfirm" class="modal-btn confirm">Confirm</button>
    </div>
  </div>
</div>
